{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role"]
    },
    "ParaphraseHistory": {
      "title": "ParaphraseHistory",
      "description": "User's paraphrase history",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "originalText": { "type": "string" },
        "paraphrasedText": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "originalText", "paraphrasedText"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Users collection"
    },
    "/paraphrase_history/{historyId}": {
      "schema": { "$ref": "#/entities/ParaphraseHistory" },
      "description": "Paraphrase history collection"
    }
  }
}
